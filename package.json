{
  "name": "career-app",
  "version": "1.0.0",
  "scripts": {
    "build": "cd client && npm run build",
    "start": "cd server && node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "server": "cd server && nodemon server.js"
  },
  "dependencies": {
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
